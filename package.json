{
  "name": "grip-knowledge-engine",
  "version": "0.4.2",
  "private": true,
  "description": "GRIP Knowledge Work Engine",
  "author": {
    "name": "CodeTonight",
    "email": "devdev@sudonum.com"
  },
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "next dev",
    "dev:network": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "electron:dev": "concurrently \"npm run dev\" \"npm run electron:start\"",
    "electron:start": "wait-on http://localhost:3000 && tsc -p electron/tsconfig.json && NODE_ENV=development electron .",
    "electron:build": "bash scripts/build-electron.sh mac arm64 dmg",
    "electron:pack": "bash scripts/build-electron.sh mac arm64 dir",
    "commander:dev": "concurrently \"npm run dev\" \"npm run electron:start\"",
    "commander:pack": "bash scripts/build-electron.sh mac arm64 dir",
    "commander:dmg": "bash scripts/build-electron.sh mac arm64 dmg",
    "commander:dmg:x64": "bash scripts/build-electron.sh mac x64 dmg",
    "build:electron:mac:arm64": "bash scripts/build-electron.sh mac arm64 dmg",
    "build:electron:mac:x64": "bash scripts/build-electron.sh mac x64 dmg",
    "build:electron:win:x64": "bash scripts/build-electron.sh win x64 nsis",
    "build:electron:linux:x64": "bash scripts/build-electron.sh linux x64 appimage",
    "verify:native-arch": "node scripts/verify-native-arch.mjs"
  },
  "build": {
    "appId": "co.codetonight.grip",
    "productName": "GRIP Commander",
    "publish": {
      "provider": "github",
      "owner": "CodeTonight-SA",
      "repo": "GRIP-GUI"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/dist/**/*",
      "electron/resources/**/*",
      "out/**/*",
      "node_modules/**/*",
      "!node_modules/@next/swc*",
      "!node_modules/@next/env",
      "!node_modules/@next/eslint-plugin-next",
      "skills/**/*",
      "hooks/**/*",
      "grip-starter/**/*"
    ],
    "asarUnpack": [
      "out/**/*",
      "hooks/**/*",
      "grip-starter/**/*",
      "electron/resources/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/node-pty/**/*"
    ],
    "extraResources": [
      {
        "from": "mcp-orchestrator",
        "to": "mcp-orchestrator",
        "filter": [
          "package.json",
          "dist/bundle.js"
        ]
      },
      {
        "from": "mcp-telegram",
        "to": "mcp-telegram",
        "filter": [
          "package.json",
          "dist/bundle.js"
        ]
      },
      {
        "from": "mcp-kanban",
        "to": "mcp-kanban",
        "filter": [
          "package.json",
          "dist/bundle.js"
        ]
      },
      {
        "from": "mcp-vault",
        "to": "mcp-vault",
        "filter": [
          "package.json",
          "dist/bundle.js"
        ]
      },
      {
        "from": "mcp-socialdata",
        "to": "mcp-socialdata",
        "filter": [
          "package.json",
          "dist/bundle.js"
        ]
      },
      {
        "from": "mcp-x",
        "to": "mcp-x",
        "filter": [
          "package.json",
          "dist/bundle.js"
        ]
      },
      {
        "from": "mcp-world",
        "to": "mcp-world",
        "filter": [
          "package.json",
          "dist/bundle.js"
        ]
      }
    ],
    "afterSign": "scripts/notarize.js",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "public/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "icon": "public/icon.png",
      "category": "Development",
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "GRIP-Commander-${version}-${arch}.${ext}"
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "GRIP-Commander-${version}-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico"
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0"
      ]
    },
    "dmg": {
      "artifactName": "GRIP-Commander-${version}-${arch}.${ext}",
      "title": "GRIP Commander",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@slack/bolt": "^4.6.0",
    "better-sqlite3": "^11.0.0",
    "call-bind": "^1.0.8",
    "call-bind-apply-helpers": "^1.0.2",
    "dunder-proto": "^1.0.1",
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.29.0",
    "get-intrinsic": "^1.3.0",
    "get-proto": "^1.0.1",
    "lucide-react": "^0.563.0",
    "next": "^16.2.1",
    "node-pty": "^1.1.0",
    "node-telegram-bot-api": "^0.67.0",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-grid-layout": "^2.2.2",
    "set-function-length": "^1.2.2",
    "three": "^0.182.0",
    "uuid": "^9.0.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^4.0.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20",
    "@types/node-telegram-bot-api": "^0.64.13",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^9.0.8",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "jsdom": "^29.0.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.1"
  }
}
